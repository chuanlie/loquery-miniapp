.container { background: #F8F5F7; min-height: 100vh; padding: 4rpx 24rpx 0; }

.section {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #EDE6EC;
  overflow: hidden;
}
.section-title { font-size: 28rpx; font-weight: 700; color: #3D3242; margin-bottom: 18rpx; }
.required { color: #E89AB1; }

/* 标签 */
.tag-list { display: flex; flex-wrap: wrap; gap: 14rpx; margin-bottom: 20rpx; }
.tag {
  background: #FAF6F8;
  border: 1.5rpx solid #EDE6EC;
  border-radius: 40rpx;
  padding: 12rpx 26rpx;
  font-size: 26rpx;
  color: #9B8A9A;
}
.tag-active {
  background: #FDF0F5;
  color: #D4809C;
  border-color: #EDBED0;
  font-weight: 700;
}

/* 账号输入行（固定显示） */
.account-row-default {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #FAF6F8;
  border: 1.5rpx solid #EDE6EC;
  border-radius: 14rpx;
  padding: 0 20rpx;
}
.account-label-default {
  font-size: 26rpx;
  color: #9B8A9A;
  white-space: nowrap;
  flex-shrink: 0;
  padding: 20rpx 0;
  border-right: 1rpx solid #EDE6EC;
  padding-right: 16rpx;
  margin-right: 4rpx;
}
.account-input {
  flex: 1;
  font-size: 26rpx;
  color: #3D3242;
  padding: 20rpx 0;
  background: transparent;
}

/* 文本域 */
.textarea {
  width: 100%;
  background: #FAF6F8;
  border-radius: 14rpx;
  padding: 18rpx 20rpx;
  font-size: 26rpx;
  color: #3D3242;
  border: 1.5rpx solid #EDE6EC;
  min-height: 170rpx;
  box-sizing: border-box;
}
.char-count { font-size: 22rpx; color: #C4B0C0; float: right; margin-top: 10rpx; }

/* 截图列表 */
.img-list { display: flex; flex-wrap: wrap; gap: 14rpx; margin-bottom: 16rpx; }
.img-item { position: relative; width: 190rpx; height: 190rpx; }
.img-thumb { width: 100%; height: 100%; border-radius: 14rpx; }
.img-del {
  position: absolute; top: -14rpx; right: -14rpx;
  background: #E89AB1; color: #fff;
  width: 44rpx; height: 44rpx;
  border-radius: 50%; font-size: 28rpx;
  display: flex; align-items: center; justify-content: center; line-height: 1;
}

/* 上传条（全宽，强化可操作感） */
.img-add-bar {
  display: flex;
  align-items: center;
  gap: 18rpx;
  background: #FDF6F9;
  border: 2rpx dashed #E8C0D4;
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
}
.img-add-bar-icon { font-size: 44rpx; flex-shrink: 0; }
.img-add-bar-text { flex: 1; }
.img-add-bar-title { font-size: 28rpx; color: #3D3242; font-weight: 600; display: block; }
.img-add-bar-hint { font-size: 22rpx; color: #C4B0C0; display: block; margin-top: 4rpx; }
.img-add-bar-arrow { font-size: 36rpx; color: #D4B8C8; flex-shrink: 0; }
.img-count-tip { font-size: 22rpx; color: #E89AB1; display: block; margin-top: 12rpx; }

/* 联系方式 */
.input {
  display: block;
  width: 100%;
  background: #FAF6F8;
  border-radius: 14rpx;
  padding: 20rpx 22rpx;
  font-size: 28rpx;
  color: #3D3242;
  border: 1.5rpx solid #EDE6EC;
  box-sizing: border-box;
}

/* 提示框 */
.tip-box {
  background: #fff;
  border-radius: 16rpx;
  padding: 18rpx 22rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #EDE6EC;
  overflow: hidden;
}
.tip-text { font-size: 23rpx; color: #A898A8; line-height: 1.7; }

/* 提交按钮 */
.submit-btn {
  background: #3D3242;
  color: #fff;
  border-radius: 18rpx;
  font-size: 32rpx;
  font-weight: 700;
  height: 100rpx;
  line-height: 100rpx;
  letter-spacing: 2rpx;
  box-shadow: 0 6rpx 20rpx rgba(61,50,66,.28);
  margin-bottom: 0;
}
.submit-btn::after { border: none; }

/* 底部安全区 */
.safe-bottom {
  height: constant(safe-area-inset-bottom);
  height: env(safe-area-inset-bottom);
  min-height: 32rpx;
}
