page {
  background: #FFF9FB;
  font-family: -apple-system, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  color: #3D3242;
  box-sizing: border-box;
}
.container { padding: 0 24rpx 48rpx; }

.tag-high { background: rgba(217,122,114,.15); color: #D97A72; border-radius: 8rpx; padding: 4rpx 14rpx; font-size: 22rpx; font-weight: 700; border: 1rpx solid rgba(217,122,114,.3); }
.tag-mid  { background: rgba(196,154,82,.15); color: #C49A52; border-radius: 8rpx; padding: 4rpx 14rpx; font-size: 22rpx; font-weight: 700; border: 1rpx solid rgba(196,154,82,.3); }
.tag-low  { background: rgba(180,160,180,.12); color: #9B8A9A; border-radius: 8rpx; padding: 4rpx 14rpx; font-size: 22rpx; font-weight: 700; }
